# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Solo servidor — NUNCA con prefijo NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Motor de IA — doble proveedor:
# Si defines ANTHROPIC_API_KEY se usa Claude (claude-haiku-4-5, recomendado);
# si no, se usa Groq. IA_PROVEEDOR=anthropic|groq fuerza uno explícitamente.
# Anthropic (https://console.anthropic.com/settings/keys) — sk-ant-...
ANTHROPIC_API_KEY=sk-ant-...
# Groq (https://console.groq.com/keys) — gsk_... (ojo: Groq, NO Grok/xAI xai-...)
GROQ_API_KEY=gsk_...
